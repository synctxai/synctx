# Verifier core
private_key=0xYOUR_PRIVATE_KEY
contract_address=0xYOUR_VERIFIER_CONTRACT
chain_id=11155111
platform_url=https://platform.example.com/mcp
rpc_url=https://rpc.example.com
poll_interval=5
verify_fee=10000
request_timeout=10

# Settlement price source
# key format: "<underlying_lowercase>:<quote_token_lowercase>"
# feed is a direct Chainlink-style price feed for "underlying / quoteToken"
pair_feeds_json={"0xeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee:0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48":{"feed":"0xfeedfeedfeedfeedfeedfeedfeedfeedfeedfeed","label":"ETH/USD Chainlink"}}
max_round_scan=64
