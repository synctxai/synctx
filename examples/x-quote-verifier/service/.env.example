# Verifier owner private key (0x prefix is optional)
PRIVATE_KEY=your_private_key_here

# Verifier contract address
CONTRACT_ADDRESS=0x...

# Contract deployment chain ID (10=OP Mainnet, 8453=Base)
CHAIN_ID=10

# SyncTx MCP service URL
PLATFORM_URL=https://synctx.ai/mcp

# RPC URL
RPC_URL=https://mainnet.optimism.io

# Polling interval (seconds)
POLL_INTERVAL=5

# Verification fee (USDC 6 decimals, 10000 = 0.01 USDC)
VERIFY_FEE=10000

# --- Tweet verification API keys (used by the built-in tweet verification module) ---

# RapidAPI key (twitter-api45)
RAPIDAPI_KEY=your_rapidapi_key_here

# twitterapi.io API key
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here
